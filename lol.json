let totalBandwidth = 0;
const resetCondition = 1000000000; // 1 GB for example

// Load the previous bandwidth usage if stored
if ($persistentStore.read("totalBandwidth")) {
  totalBandwidth = parseInt($persistentStore.read("totalBandwidth"));
}

// Function to reset bandwidth
function resetBandwidth() {
  totalBandwidth = 0;
  $persistentStore.write("0", "totalBandwidth");
  $notification.post("Bandwidth Reset", "Bandwidth usage has been reset.", "");
}

// Main script
$httpClient.get($request.url, function(error, response, data) {
  if (error) {
    $done();
  } else {
    const responseSize = response.headers["Content-Length"] ? parseInt(response.headers["Content-Length"]) : 0;
    totalBandwidth += responseSize;
    $persistentStore.write(totalBandwidth.toString(), "totalBandwidth");

    if (totalBandwidth >= resetCondition) {
      resetBandwidth();
    }

    $done({response: {status: response.status, headers: response.headers, body: data}});
  }
});